    "version": "0.2.0",
    "configurations": [
        {
            "name": "UI: debug (no reload)",
            "type": "debugpy",
            "request": "launch",
            "module": "lore",
            "args": ["ui"],
            "jinja": true,
            "justMyCode": false,
            "subProcess": true
        },
        {
            "name": "UI: dev (with reload)",
            "type": "debugpy",
            "request": "launch",
            "module": "lore",
            "args": ["ui", "--reload"],
            "jinja": true,
            "justMyCode": false,
            "subProcess": true
        }
    ]
}